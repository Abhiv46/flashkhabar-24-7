# Optional — set this in Vercel → Project → Settings → Environment Variables
# to enable AI-rewritten, original summaries (recommended for SEO).
# Without it, the site falls back to the raw RSS description automatically.
ANTHROPIC_API_KEY=

# Set this to your real domain once you buy one — used in canonical URLs,
# sitemap.xml, and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://flashkhabar.example.com
